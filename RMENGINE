function selectAttender(id){
  assignSelectedAttender=id;
  document.querySelectorAll('.att-select-row').forEach(r=>r.classList.remove('chosen'));
  document.getElementById('arow-'+id)?.classList.add('chosen');
}

function confirmAssign(){
  if(!assignSelectedAttender){toast('Please select an attender','red');return;}
  const t=tickets.find(x=>x.id===activeTicketId);
  if(!t) return;
  const att=ATTENDERS.find(a=>a.id===assignSelectedAttender);
  const amt=parseFloat(document.getElementById('assign-amount').value)||0;
  const note=document.getElementById('assign-note').value;
  const wasReassign=!!t.attenderId;
  t.attenderId=assignSelectedAttender;
  t.transferAmount=amt;
  t.status='In Progress';
  addTimeline(t,wasReassign?'Re-assigned to Attender':'Assigned to Attender',
    `Assigned to ${att.name}${amt?`. ₹${amt.toLocaleString('en-IN')} transferred for purchases`:''}.${note?' Note: '+note:''}`);
  closeModal('modal-assign');
  toast(`✅ Assigned to ${att.name}${amt?`, ₹${amt.toLocaleString('en-IN')} transferred`:''}`, 'green');
  buildNav(); navigateTo('dashboard');
}

// ═══════════════════════════════════════════════════════
//  QUOTATION / ATTENDER ACCEPT
// ═══════════════════════════════════════════════════════
function openQuotModal(id){
  activeTicketId=id;
  ['q-vendor','q-amount','q-scope'].forEach(i=>document.getElementById(i).value='');
  document.getElementById('q-date').value=new Date(Date.now()+7*86400000).toISOString().split('T')[0];
  openModal('modal-quot');
}

function submitQuot(){
  const vendor=document.getElementById('q-vendor').value;
  const amount=document.getElementById('q-amount').value;
  if(!vendor||!amount){toast('Please fill vendor and amount','red');return;}
  const t=tickets.find(x=>x.id===activeTicketId);
  if(!t) return;
  t.vendor=vendor;
  t.quotation=parseFloat(amount);
  t.scope=document.getElementById('q-scope').value;
  t.cashflow=document.getElementById('q-cashflow').value;
  t.status='Pending Approval';
  addTimeline(t,'Quotation Submitted',`₹${t.quotation.toLocaleString('en-IN')} by ${vendor}. Sent to manager for approval.`);
  closeModal('modal-quot');
  toast(`📋 Quotation ₹${t.quotation.toLocaleString('en-IN')} submitted for approval`,'green');
  buildNav(); navigateTo('dashboard');
}

// Attender accepts job
function attenderAccept(id){
  const t=tickets.find(x=>x.id===id);
  if(!t) return;
  t.status='Accepted';
  addTimeline(t,'Accepted by Attender','Attender has accepted the job and will visit the location.');
  closeModal('modal-detail');
  toast('✅ Job accepted!','green');
  navigateTo('my-jobs');
}

// ═══════════════════════════════════════════════════════
//  MANAGER ACTIONS
// ═══════════════════════════════════════════════════════
function managerApprove(id){
  const t=tickets.find(x=>x.id===id);
  if(!t) return;
  t.status='Approved';
  addTimeline(t,'Manager Approved',`Quotation of ₹${(t.quotation||0).toLocaleString('en-IN')} approved. Work can proceed.`);
  toast('✅ Ticket approved!','green');
  buildNav(); navigateTo('approvals');
}

function managerReject(id){
  const t=tickets.find(x=>x.id===id);
  if(!t) return;
  t.status='Pending Finance';
  addTimeline(t,'Returned by Manager','Manager returned quotation for review. Please revise and resubmit.');
  toast('↩ Returned to Finance','yellow');
  buildNav(); navigateTo('approvals');
}

function reopenTicket(id){
  const t=tickets.find(x=>x.id===id);
  if(!t) return;
  t.status='Reopened';
  t.attenderId=null;
  addTimeline(t,'Ticket Reopened','Supervisor reopened the ticket for reassignment.');
  closeModal('modal-detail');
  toast('🔄 Ticket reopened','yellow');
  buildNav(); navigateTo('dashboard');
}

// ═══════════════════════════════════════════════════════
//  NEW TICKET
// ═══════════════════════════════════════════════════════
function openNewTicketModal(){
  document.getElementById('nt-kitchen').value=currentUser.kitchenCode||'';
  document.getElementById('nt-name').value=currentUser.name||'';
  ['nt-title','nt-dept','nt-subcat','nt-priority'].forEach(id=>{
    const el=document.getElementById(id); if(el){el.value='';el.classList.remove('err');}
  });
  openModal('modal-new-ticket');
}

function loadSubCat(){
  const dept = document.getElementById('nt-dept').value;
  const sub = document.getElementById('nt-subcat');

  sub.innerHTML = '<option value="">Select</option>';

  if(SUB_CAT[dept]){
    SUB_CAT[dept].forEach(s=>{
      const opt = document.createElement('option');
      opt.value = s;
      opt.textContent = s;
      sub.appendChild(opt);
    });
  }
}


function submitTicket(){
  const name=document.getElementById('nt-name').value.trim();
  const title=document.getElementById('nt-title').value.trim();
  const dept=document.getElementById('nt-dept').value;
  const subcat=document.getElementById('nt-subcat').value;
  const priority=document.getElementById('nt-priority').value;

  let ok=true;

  const check=(id,errId,val)=>{
    const el=document.getElementById(id),
          er=document.getElementById(errId);

    if(!val){
      if(el)el.classList.add('err');
      if(er)er.classList.add('show');
      ok=false;
    }else{
      if(el)el.classList.remove('err');
      if(er)er.classList.remove('show');
    }
  };

  check('nt-name','err-nt-name',name);
  check('nt-title','err-nt-title',title);
  check('nt-dept','err-nt-dept',dept);
  check('nt-subcat','err-nt-subcat',subcat);
  check('nt-priority','err-nt-priority',priority);

  if(!ok){
    toast('Please fill all required fields','red');
    return;
  }

  const newId = tid(); // ✅ FIX ADDED

  const t={
    id:newId, // ✅ FIXED
    kitchenCode:currentUser.kitchenCode,
    requesterName:name,
    title, dept, subcat, priority,
    impact:document.getElementById('nt-impact').value,
    desc:document.getElementById('nt-desc').value,
    cost:parseFloat(document.getElementById('nt-cost').value)||0,
    status:'Open',
    date:now(),
    otp:genOTP(),
    timeline:[
      {step:'Submitted',done:true,time:now(),note:`Raised by ${name}`},
      {step:'Ticket Created',done:true,time:now(),note:`${newId} generated`}, // ✅ FIXED
      {step:'Assigned to Attender',done:false,time:'',note:'Awaiting supervisor action'},
      {step:'Accepted by Attender',done:false,time:'',note:''},
      {step:'Attender Reached',done:false,time:'',note:''},
      {step:'Quotation Submitted',done:false,time:'',note:''},
      {step:'Pending Manager Approval',done:false,time:'',note:''},
      {step:'Work Completed',done:false,time:'',note:''},
      {step:'Closed',done:false,time:'',note:''},
    ]
  };

  tickets.unshift(t);

  closeModal('modal-new-ticket');
  toast(`✅ Ticket ${t.id} submitted!`,'green');
  buildNav();
  navigateTo('dashboard');
}
// ═══════════════════════════════════════════════════════
//  HELPERS
// ═══════════════════════════════════════════════════════
function addTimeline(t,step,note=''){
  const existing=t.timeline.find(s=>s.step===step);
  if(existing){existing.done=true;existing.time=now();existing.note=note;}
  else t.timeline.push({step,done:true,time:now(),note});
}

function openModal(id){ document.getElementById(id)?.classList.add('open'); }
function closeModal(id){ document.getElementById(id)?.classList.remove('open'); }

function toast(msg,type='green'){
  const wrap=document.getElementById('toast-wrap');
  const el=document.createElement('div');
  el.className='toast';
  const colors={green:'var(--green)',red:'var(--red)',blue:'var(--blue)',yellow:'var(--accent)'};
  el.style.borderLeftColor=colors[type]||'var(--accent)';
  el.textContent=msg;
  wrap.appendChild(el);
  setTimeout(()=>el.remove(),4500);
}

// Close modals on overlay click
document.addEventListener('click',e=>{
  if(e.target.classList.contains('overlay')) closeModal(e.target.id);
});

// ═══════════════════════════════════════════════════════
//  INIT
// ═══════════════════════════════════════════════════════
function boot(){
  // Populate kitchen dropdown
  const kd=document.getElementById('login-kitchen');
  KITCHENS.forEach(k=>{ const o=document.createElement('option');o.value=k;o.textContent=k;kd.appendChild(o); });

  // Populate attender dropdown
  const ad=document.getElementById('login-attender');
  ATTENDERS.forEach(a=>{ const o=document.createElement('option');o.value=a.id;o.textContent=`${a.name} (${a.id})`;ad.appendChild(o); });

  seedData();

  // Auto-login if stored
  const stored=localStorage.getItem('rmUser');
  if(stored){ try{ currentUser=JSON.parse(stored); initApp(); }catch(e){ localStorage.removeItem('rmUser'); } }
}

window.addEventListener('DOMContentLoaded',boot);
window.addEventListener('keydown',e=>{ if(e.key==='Enter'&&document.getElementById('screen-login').classList.contains('active')) doLogin(); });
</script>
