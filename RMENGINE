function togglePurchase(id,checked){
  if(!mediaCaptures[id]) mediaCaptures[id]={};
  mediaCaptures[id].purchaseRequired=checked;
  document.getElementById('purchase-fields').style.display=checked?'':'none';
}

function captureGeo(id,type){
  if(!navigator.geolocation){toast('Geolocation not supported','red');return;}
  navigator.geolocation.getCurrentPosition(pos=>{
    const txt=`📍 ${pos.coords.latitude.toFixed(5)}, ${pos.coords.longitude.toFixed(5)} (±${Math.round(pos.coords.accuracy)}m)`;
    if(!mediaCaptures[id]) mediaCaptures[id]={};
    if(type==='reach') mediaCaptures[id].reachGeo=txt;
    if(type==='purchase') mediaCaptures[id].purchaseGeo=txt;
    const el=document.getElementById(`geo-${type}`);
    if(el){el.textContent=txt;el.classList.add('show');}
    toast('📍 Location captured!','green');
  },err=>{
    const fallback=`📍 Simulated: 12.97${Math.floor(Math.random()*99)}, 77.59${Math.floor(Math.random()*99)} (GPS)`;
    if(!mediaCaptures[id]) mediaCaptures[id]={};
    if(type==='reach') mediaCaptures[id].reachGeo=fallback;
    if(type==='purchase') mediaCaptures[id].purchaseGeo=fallback;
    const el=document.getElementById(`geo-${type}`);
    if(el){el.textContent=fallback;el.classList.add('show');}
    toast('📍 Location captured (simulated)','green');
  });
}

function triggerCamera(id,type){
  // Create a file input and simulate camera
  const input=document.createElement('input');
  input.type='file'; input.accept='image/*,video/*'; input.capture='environment';
  input.onchange=e=>{
    const file=e.target.files[0];
    if(!file) return;
    if(!mediaCaptures[id]) mediaCaptures[id]={};
    const key=type==='reach'?'reachMedia':type==='bill'?'billMedia':'fixMedia';
    if(!mediaCaptures[id][key]) mediaCaptures[id][key]=[];
    const url=URL.createObjectURL(file);
    mediaCaptures[id][key].push({url,name:file.name,type:file.type});
    const prev=document.getElementById(`prev-${type}`);
    if(prev) prev.innerHTML=renderPreviews(mediaCaptures[id][key]);
    toast('📸 Media attached!','green');
  };
  input.click();
}

function renderPreviews(media){
  if(!media||!media.length) return '';
  return media.map(m=>m.type.startsWith('video')?
    `<video src="${m.url}" class="preview-thumb" controls></video>`:
    `<img src="${m.url}" class="preview-thumb" alt="capture">`
  ).join('');
}

function savePurchaseDetails(id){
  if(!mediaCaptures[id]) mediaCaptures[id]={};
  mediaCaptures[id].purchaseVendor=document.getElementById('pu-vendor')?.value||'';
  mediaCaptures[id].purchaseAmount=document.getElementById('pu-amount')?.value||0;
  const t=tickets.find(x=>x.id===id);
  if(t&&mediaCaptures[id].purchaseRequired){
    t.status='Purchase Done';
    addTimeline(t,'Purchase Completed',`Vendor: ${mediaCaptures[id].purchaseVendor}, ₹${mediaCaptures[id].purchaseAmount}`);
  }
  toast('💾 Purchase details saved','green');
}

function markReached(id){
  const t=tickets.find(x=>x.id===id);
  if(!t) return;
  t.status='Reached';
  addTimeline(t,'Attender Reached',`Location verified${(mediaCaptures[id]?.reachGeo?': '+mediaCaptures[id].reachGeo:'')}`);
  closeModal('modal-attender-update');
  toast('✅ Marked as Reached. Now fix the issue!','green');
  navigateTo('my-jobs');
}

function markFixed(id){
  const t=tickets.find(x=>x.id===id);
  if(!t) return;
  t.status='Fixed';
  addTimeline(t,'Issue Fixed','Attender has fixed the issue. Awaiting OTP confirmation.');
  closeModal('modal-attender-update');
  toast('🔧 Marked as Fixed. Get OTP from requester to close.','green');
  navigateTo('my-jobs');
}

// ═══════════════════════════════════════════════════════
//  OTP
// ═══════════════════════════════════════════════════════
function openOTPVerify(id){
  activeTicketId=id;
  document.getElementById('otp-input').value='';
  document.getElementById('otp-err').style.display='none';
  openModal('modal-otp');
}

function verifyOTP(){
  const t=tickets.find(x=>x.id===activeTicketId);
  if(!t) return;
  const entered=document.getElementById('otp-input').value.trim();
  if(entered!==t.otp){
    document.getElementById('otp-err').style.display='block';
    document.getElementById('otp-input').classList.add('err');
    return;
  }
  const cap=mediaCaptures[activeTicketId]||{};
  t.status='Closed';
  t.closedAt=now();
  t.finalAmount=parseFloat(cap.invoiceAmt)||t.quotation||0;
  t.closureNotes=cap.closeNotes||'';
  addTimeline(t,'Closed','OTP verified by requester. Ticket successfully closed.');
  closeModal('modal-otp');
  closeModal('modal-attender-update');
  toast(`✅ Ticket ${t.id} closed!`,'green');
  // Prompt feedback on requester side (simulate)
  setTimeout(()=>{ if(currentUser.role==='attender') toast('📧 Feedback request sent to requester','blue'); },800);
  navigateTo('my-jobs');
}

// ═══════════════════════════════════════════════════════
//  FEEDBACK
// ═══════════════════════════════════════════════════════
function openFeedback(id){
  const t=tickets.find(x=>x.id===id);
  if(!t) return;
  activeTicketId=id;
  feedbackRating=0;
  document.getElementById('fb-tid').textContent=t.id;
  document.getElementById('fb-comment').value='';
  setRating(0);
  const att=t.attenderId?ATTENDERS.find(a=>a.id===t.attenderId):null;
  document.getElementById('fb-attender-card').innerHTML=att?`
    <div class="attender-card">
      <div class="att-avatar">🛠️</div>
      <div class="att-info">
        <div class="att-name">${att.name}</div>
        <div class="att-role">Attender · ${att.id}</div>
        <div class="att-rating"><span class="att-stars">${'★'.repeat(Math.round(att.avgRating))}${'☆'.repeat(5-Math.round(att.avgRating))}</span><span class="att-count">${att.avgRating.toFixed(1)} (${att.totalRatings} ratings)</span></div>
      </div>
    </div>`:'' ;
  closeModal('modal-detail');
  openModal('modal-feedback');
}

function setRating(n){
  feedbackRating=n;
  const labels=['','Poor','Below average','Average','Good','Excellent!'];
  document.getElementById('fb-label').textContent=n?labels[n]:'Select rating';
  document.querySelectorAll('#fb-stars .star').forEach((s,i)=>s.classList.toggle('lit',i<n));
}

function submitFeedback(){
  const t=tickets.find(x=>x.id===activeTicketId);
  if(!t){closeModal('modal-feedback');return;}
  if(!feedbackRating){toast('Please select a rating','red');return;}
  t.rating=feedbackRating;
  t.feedbackComment=document.getElementById('fb-comment').value;
  // Update attender avg rating
  const att=ATTENDERS.find(a=>a.id===t.attenderId);
  if(att){
    const total=att.avgRating*att.totalRatings+feedbackRating;
    att.totalRatings++;
    att.avgRating=Math.round((total/att.totalRatings)*10)/10;
  }
  closeModal('modal-feedback');
  toast(`⭐ Thank you! You rated ${feedbackRating}/5`,'green');
  navigateTo('dashboard');
}

