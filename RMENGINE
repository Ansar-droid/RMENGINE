// ═══════════════════════════════════════════════════════
//  TICKET DETAIL MODAL
// ═══════════════════════════════════════════════════════
function openDetail(id){
  const t=tickets.find(x=>x.id===id);
  if(!t){toast('Ticket not found','red');return;}
  activeTicketId=id;
  const att=t.attenderId?ATTENDERS.find(a=>a.id===t.attenderId):null;

  document.getElementById('md-title').textContent=t.title;
  document.getElementById('md-sub').textContent=`${t.id} · ${t.dept} · ${t.kitchenCode}`;

  // Meta grid
  const meta=[
    {k:'Status',v:statusBadge(t.status)},
    {k:'Priority',v:priDot(t.priority)},
    {k:'Kitchen',v:`<span style="font-family:var(--mono);font-size:12px">${t.kitchenCode}</span>`},
    {k:'Requester',v:t.requesterName||'-'},
    {k:'Raised',v:t.date},
    {k:'Department',v:t.dept+(t.subcat?` / ${t.subcat}`:'')},
    {k:'Business Impact',v:t.impact||'-'},
    {k:'Quotation',v:t.quotation?`<span class="amount-pill">${fmtAmt(t.quotation)}</span>`:'Not yet'},
    {k:'Attender',v:att?`<span style="font-weight:600">${att.name}</span>`:'Unassigned'},
    {k:'Transfer',v:t.transferAmount?`<span class="amount-pill" style="color:var(--cyan)">${fmtAmt(t.transferAmount)}</span>`:'None'},
  ];

  let body=`<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:20px;padding-bottom:20px;border-bottom:1px solid var(--border)">
    ${meta.map(m=>`<div><div style="font-size:10px;color:var(--muted);font-family:var(--mono);text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px">${m.k}</div><div style="font-size:13px;font-weight:600">${m.v}</div></div>`).join('')}
  </div>`;

  // Requester OTP (only show to requester)
  if(currentUser.role==='requester'&&t.status!=='Closed'){
    body+=`<div style="margin-bottom:20px;padding-bottom:20px;border-bottom:1px solid var(--border)">
      <div style="font-size:11px;color:var(--muted);font-family:var(--mono);text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px">Your OTP — Share with Attender when work is done</div>
      <div class="otp-box">${t.otp||'—'}</div>
      <div style="font-size:12px;color:var(--muted);text-align:center">Share this only when you are satisfied with the work</div>
    </div>`;
  }

  // Feedback button for requester on closed ticket without rating
  if(currentUser.role==='requester'&&t.status==='Closed'&&!t.rating){
    body+=`<div style="margin-bottom:20px"><button class="btn btn-primary" onclick="openFeedback('${t.id}')">⭐ Rate this Service</button></div>`;
  }
  if(t.rating){
    body+=`<div style="margin-bottom:20px;padding:14px;background:rgba(240,165,0,.06);border-radius:var(--radius);border:1px solid rgba(240,165,0,.2)">
      <div style="font-size:11px;color:var(--muted);font-family:var(--mono);margin-bottom:6px">YOUR RATING</div>
      <div style="font-size:20px;color:var(--accent)">${'★'.repeat(t.rating)}${'☆'.repeat(5-t.rating)} <span style="font-size:14px;font-weight:600">${t.rating}/5</span></div>
      ${t.feedbackComment?`<div style="font-size:13px;color:var(--muted);margin-top:6px">"${t.feedbackComment}"</div>`:''}
    </div>`;
  }

  // Timeline
  body+=`<div style="margin-bottom:20px"><div style="font-size:11px;color:var(--muted);font-family:var(--mono);text-transform:uppercase;letter-spacing:.5px;margin-bottom:14px">Ticket Timeline</div>
    <div class="timeline">${(t.timeline||[]).map((step,i)=>{
      const activeIdx=(t.timeline||[]).findIndex(s=>!s.done);
      const cls=step.done?'done':(i===activeIdx?'active':'');
      return `<div class="tl-item ${cls}">
        <div class="tl-dot">${step.done?'✓':(i+1)}</div>
        <div class="tl-body"><h4>${step.step}</h4>${step.note?`<p>${step.note}</p>`:''}<div class="tl-time">${step.time||'Pending'}</div></div>
      </div>`;
    }).join('')}</div>
  </div>`;

  // Action buttons
  let actions='';
  const r=currentUser.role;
  if(r==='supervisor'){
    if(!t.attenderId) actions+=`<button class="btn btn-primary btn-sm" onclick="openAssignModal('${t.id}');closeModal('modal-detail')">Assign Attender</button>`;
    else actions+=`<button class="btn btn-outline btn-sm" onclick="openAssignModal('${t.id}');closeModal('modal-detail')">Re-assign</button>`;
    if(t.status==='Pending Finance') actions+=`<button class="btn btn-blue btn-sm" onclick="openQuotModal('${t.id}');closeModal('modal-detail')">Add Quotation</button>`;
    if(t.status==='Closed') actions+=`<button class="btn btn-outline btn-sm" onclick="reopenTicket('${t.id}')">Re-open</button>`;
  }
  if(r==='manager'){
    if(t.status==='Pending Approval') actions+=`<button class="btn btn-green btn-sm" onclick="managerApprove('${t.id}');closeModal('modal-detail')">Approve</button><button class="btn btn-outline btn-sm" onclick="managerReject('${t.id}');closeModal('modal-detail')">Return</button>`;
  }
  if(actions) body+=`<div style="display:flex;gap:8px;flex-wrap:wrap;padding-top:16px;border-top:1px solid var(--border)">${actions}</div>`;

  document.getElementById('md-body').innerHTML=body;
  openModal('modal-detail');
}

