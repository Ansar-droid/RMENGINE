    {id:'dashboard',icon:'📊',label:'My Dashboard'},
    {id:'my-jobs',icon:'🔧',label:'My Jobs',badge:'active'},
    {id:'history',icon:'📁',label:'Job History'},
    {id:'profile',icon:'👤',label:'My Profile'},
  ]
};

function buildNav(){
  const nav = document.getElementById('sidebar-nav');
  nav.innerHTML='';
  const items = NAV_CONFIG[currentUser.role]||[];
  nav.innerHTML='<div class="nav-label">Navigation</div>';
  items.forEach(item=>{
    const badge = item.badge ? getBadgeCount(item.badge) : 0;
    nav.innerHTML+=`<div class="nav-item" id="nav-${item.id}" onclick="navigateTo('${item.id}')">
      <span class="ni">${item.icon}</span>
      <span>${item.label}</span>
      ${badge>0?`<span class="nav-badge ${item.badge==='approvals'?'':'amber'}">${badge}</span>`:''}
    </div>`;
  });
}

function getBadgeCount(type){
  if(type==='open') return tickets.filter(t=>t.status==='Open').length;
  if(type==='unassigned') return tickets.filter(t=>!t.attenderId&&t.status!=='Closed').length;
  if(type==='approvals') return tickets.filter(t=>t.status==='Pending Approval').length;
  if(type==='active') return tickets.filter(t=>t.attenderId===currentUser.attenderId&&!['Closed'].includes(t.status)).length;
  return 0;
}

function navigateTo(view){
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  const el=document.getElementById('nav-'+view); if(el) el.classList.add('active');
  document.getElementById('page-title').textContent=({
    dashboard:'Dashboard','my-tickets':'My Tickets','all-tickets':'All Tickets',
    'assign-queue':'Assign Queue',attenders:'Attender Team',finance:'Finance',transfers:'Transfers',
    approvals:'Approvals','my-jobs':'My Jobs',history:'Job History',profile:'My Profile'
  }[view]||view);
  renderView(view);
}

// ═══════════════════════════════════════════════════════
//  VIEW ROUTER
// ═══════════════════════════════════════════════════════
function renderView(v){
  const mc = document.getElementById('main-content');
  const r = currentUser.role;
  if(v==='dashboard'){
    if(r==='requester') mc.innerHTML=renderRequesterDashboard();
    else if(r==='supervisor') mc.innerHTML=renderSupervisorDashboard();
    else if(r==='manager') mc.innerHTML=renderManagerDashboard();
    else if(r==='attender') mc.innerHTML=renderAttenderDashboard();
  } else if(v==='my-tickets') mc.innerHTML=renderMyTickets();
  else if(v==='all-tickets') mc.innerHTML=renderAllTickets();
  else if(v==='assign-queue') mc.innerHTML=renderAssignQueue();
  else if(v==='attenders') mc.innerHTML=renderAttenders();
  else if(v==='finance') mc.innerHTML=renderFinance();
  else if(v==='transfers') mc.innerHTML=renderTransfers();
  else if(v==='approvals') mc.innerHTML=renderApprovals();
  else if(v==='my-jobs') mc.innerHTML=renderMyJobs();
  else if(v==='history') mc.innerHTML=renderJobHistory();
  else if(v==='profile') mc.innerHTML=renderAttenderProfile();
  else mc.innerHTML=`<div class="empty-state"><div class="ei">🚧</div><p>Coming soon</p></div>`;
}

