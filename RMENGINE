<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>R&M Engine v2</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Sora:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#0a0c10; --surface:#111318; --surface2:#181c24; --surface3:#1e2330;
  --border:#1e2330; --border2:#252d3d;
  --accent:#f0a500; --accent2:#e05c1a;
  --green:#22c55e; --blue:#3b82f6; --red:#ef4444;
  --purple:#a855f7; --cyan:#06b6d4; --pink:#ec4899;
  --text:#e2e8f0; --muted:#64748b; --muted2:#94a3b8;
  --font:'Sora',sans-serif; --mono:'IBM Plex Mono',monospace;
  --radius:12px; --radius-lg:16px; --radius-sm:8px;
}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:var(--font);min-height:100vh;overflow-x:hidden}

/* ── SCROLLBAR ── */
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px}

/* ── SCREENS ── */
.screen{display:none;min-height:100vh}
.screen.active{display:flex}

/* ══════════════════════════════════
   LOGIN SCREEN
══════════════════════════════════ */
#screen-login{
  align-items:center;justify-content:center;
  background:radial-gradient(ellipse 80% 60% at 50% 0%,rgba(240,165,0,.08),transparent),
             radial-gradient(ellipse 60% 40% at 80% 100%,rgba(59,130,246,.06),transparent),
             var(--bg);
}
.login-wrap{width:100%;max-width:440px;padding:24px}
.login-logo{text-align:center;margin-bottom:36px}
.login-logo h1{font-size:28px;font-weight:700;letter-spacing:-.5px}
.login-logo h1 span{color:var(--accent)}
.login-logo p{font-size:12px;color:var(--muted);font-family:var(--mono);margin-top:6px}
.role-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:24px}
.role-card{
  background:var(--surface);border:1.5px solid var(--border);border-radius:var(--radius);
  padding:16px;cursor:pointer;transition:all .2s;text-align:center;
}
.role-card:hover{border-color:var(--accent);background:rgba(240,165,0,.05)}
.role-card.selected{border-color:var(--accent);background:rgba(240,165,0,.1)}
.role-card .role-icon{font-size:26px;margin-bottom:8px}
.role-card .role-name{font-size:13px;font-weight:600}
.role-card .role-sub{font-size:11px;color:var(--muted);margin-top:2px}
.login-form{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:24px}
.login-form h2{font-size:16px;font-weight:600;margin-bottom:20px}
.form-group{margin-bottom:14px}
.form-group label{display:block;font-size:11px;color:var(--muted);font-family:var(--mono);text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px}
.form-group input,.form-group select,.form-group textarea{
  width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);
  color:var(--text);font-family:var(--font);font-size:14px;padding:10px 12px;outline:none;transition:border-color .2s;
}
.form-group input:focus,.form-group select:focus,.form-group textarea:focus{border-color:var(--accent)}
.form-group input.err,.form-group select.err{border-color:var(--red)}
.err-msg{font-size:11px;color:var(--red);margin-top:4px;display:none}
.err-msg.show{display:block}
.login-btn{width:100%;padding:12px;background:var(--accent);border:none;border-radius:var(--radius-sm);color:#000;font-family:var(--font);font-size:14px;font-weight:700;cursor:pointer;margin-top:4px;transition:all .2s}
.login-btn:hover{background:#fbbf24}

/* ══════════════════════════════════
   APP LAYOUT
══════════════════════════════════ */
#screen-app{flex-direction:column}
.app-shell{display:flex;height:100vh;overflow:hidden}
.sidebar{
  width:220px;background:var(--surface);border-right:1px solid var(--border);
  display:flex;flex-direction:column;flex-shrink:0;transition:width .3s;
}
.sidebar.collapsed{width:60px}
.main-area{flex:1;overflow-y:auto;display:flex;flex-direction:column}
.topbar{
  padding:14px 24px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:12px;background:var(--surface);
  position:sticky;top:0;z-index:20;
}
.topbar-title{flex:1}
.topbar-title h1{font-size:17px;font-weight:600}
.topbar-title p{font-size:11px;color:var(--muted);font-family:var(--mono);margin-top:1px}
.topbar-user{display:flex;align-items:center;gap:10px}
.user-avatar{width:34px;height:34px;border-radius:50%;background:rgba(240,165,0,.2);border:1.5px solid var(--accent);display:flex;align-items:center;justify-content:center;font-size:14px}
.user-name{font-size:13px;font-weight:500}
.user-role{font-size:11px;color:var(--muted);font-family:var(--mono)}
.content{padding:22px 24px;flex:1}

/* SIDEBAR NAV */
.logo{padding:18px 14px 14px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px}
.logo-icon{font-size:22px;flex-shrink:0}
.logo-text{font-weight:700;font-size:14px;white-space:nowrap}
.logo-text span{color:var(--accent)}
.nav{padding:10px 8px;flex:1;overflow-y:auto}
.nav-label{font-size:10px;color:var(--muted);font-family:var(--mono);padding:8px 8px 4px;text-transform:uppercase;letter-spacing:1px;white-space:nowrap;overflow:hidden}
.nav-item{
  display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:var(--radius-sm);
  cursor:pointer;font-size:13px;color:var(--muted);transition:all .2s;margin-bottom:1px;white-space:nowrap;
}
.nav-item:hover{background:var(--surface2);color:var(--text)}
.nav-item.active{background:rgba(240,165,0,.12);color:var(--accent)}
.nav-item .ni{font-size:16px;width:20px;text-align:center;flex-shrink:0}
.nav-badge{margin-left:auto;background:var(--red);color:#fff;font-size:10px;font-weight:700;border-radius:10px;padding:1px 6px;font-family:var(--mono);flex-shrink:0}
.nav-badge.amber{background:var(--accent);color:#000}
.nav-badge.blue{background:var(--blue)}
.sidebar-footer{padding:12px 8px;border-top:1px solid var(--border)}

/* ══════════════════════════════════
   GENERIC COMPONENTS
══════════════════════════════════ */
.btn{padding:8px 16px;border-radius:var(--radius-sm);border:none;cursor:pointer;font-family:var(--font);font-size:13px;font-weight:600;transition:all .2s;display:inline-flex;align-items:center;gap:6px}
.btn-primary{background:var(--accent);color:#000}.btn-primary:hover{background:#fbbf24}
.btn-outline{background:transparent;color:var(--text);border:1px solid var(--border)}.btn-outline:hover{border-color:var(--accent);color:var(--accent)}
.btn-green{background:var(--green);color:#000}.btn-green:hover{background:#16a34a}
.btn-red{background:var(--red);color:#fff}.btn-red:hover{background:#dc2626}
.btn-blue{background:var(--blue);color:#fff}.btn-blue:hover{background:#2563eb}
.btn-purple{background:var(--purple);color:#fff}.btn-purple:hover{background:#9333ea}
.btn-sm{padding:5px 12px;font-size:12px}
.btn-xs{padding:3px 9px;font-size:11px}
.btn:disabled{opacity:.4;cursor:not-allowed}

.badge{display:inline-flex;align-items:center;gap:4px;padding:3px 9px;border-radius:20px;font-size:11px;font-weight:600;font-family:var(--mono)}
.badge::before{content:'';width:5px;height:5px;border-radius:50%;background:currentColor}
.b-open{background:rgba(59,130,246,.15);color:var(--blue)}
.b-progress{background:rgba(168,85,247,.15);color:var(--purple)}
.b-pending{background:rgba(240,165,0,.15);color:var(--accent)}
.b-approved{background:rgba(34,197,94,.15);color:var(--green)}
.b-closed{background:rgba(100,116,139,.15);color:var(--muted)}
.b-hold{background:rgba(239,68,68,.15);color:var(--red)}
.b-accepted{background:rgba(6,182,212,.15);color:var(--cyan)}

.p-dot{width:7px;height:7px;border-radius:50%;display:inline-block;margin-right:5px}
.p-critical{background:var(--red)}.p-high{background:var(--accent2)}.p-medium{background:var(--accent)}.p-low{background:var(--green)}

.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden}
.card-header{padding:16px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px}
.card-header h2{font-size:15px;font-weight:600;flex:1}
.card-header .ch-sub{font-size:11px;color:var(--muted);font-family:var(--mono);margin-top:1px}

table{width:100%;border-collapse:collapse}
thead th{padding:10px 14px;text-align:left;font-size:11px;color:var(--muted);font-family:var(--mono);text-transform:uppercase;letter-spacing:.5px;border-bottom:1px solid var(--border);background:var(--surface2)}
tbody tr{border-bottom:1px solid var(--border);transition:background .15s;cursor:pointer}
tbody tr:last-child{border-bottom:none}
tbody tr:hover{background:var(--surface2)}
td{padding:11px 14px;font-size:13px}
.tid{font-family:var(--mono);color:var(--accent);font-weight:600;font-size:12px}

.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px}
.stat-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px 18px;position:relative;overflow:hidden}
.stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--c,var(--accent))}
.stat-label{font-size:11px;color:var(--muted);font-family:var(--mono);text-transform:uppercase;letter-spacing:.5px}
.stat-val{font-size:26px;font-weight:700;margin:5px 0 1px;font-family:var(--mono)}
.stat-desc{font-size:11px;color:var(--muted)}

/* MODAL */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.8);z-index:200;display:flex;align-items:center;justify-content:center;padding:16px;opacity:0;pointer-events:none;transition:opacity .2s}
.overlay.open{opacity:1;pointer-events:all}
.modal{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);width:100%;max-width:600px;max-height:90vh;overflow-y:auto;transform:translateY(16px);transition:transform .2s}
.overlay.open .modal{transform:none}
.modal.wide{max-width:780px}
.modal-head{padding:18px 22px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;position:sticky;top:0;background:var(--surface);z-index:1}
.modal-head h2{font-size:15px;font-weight:700;flex:1}
.close-x{background:none;border:none;color:var(--muted);cursor:pointer;font-size:20px;padding:2px 8px;line-height:1}
.close-x:hover{color:var(--text)}
.modal-body{padding:22px}
.modal-foot{padding:14px 22px;border-top:1px solid var(--border);display:flex;gap:10px;justify-content:flex-end}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.form-grid .full{grid-column:1/-1}
.form-group textarea{resize:vertical;min-height:72px}

/* TOASTS */
.toast-wrap{position:fixed;bottom:20px;right:20px;z-index:999;display:flex;flex-direction:column;gap:8px;pointer-events:none}
.toast{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);padding:11px 16px;min-width:260px;max-width:340px;font-size:13px;box-shadow:0 8px 32px rgba(0,0,0,.5);animation:tin .3s ease;border-left:3px solid var(--accent)}
@keyframes tin{from{transform:translateX(110%);opacity:0}to{transform:none;opacity:1}}

/* TIMELINE */
.timeline{display:flex;flex-direction:column;gap:0}
.tl-item{display:flex;gap:14px;padding:10px 0;position:relative}
.tl-item:not(:last-child)::after{content:'';position:absolute;left:11px;top:34px;bottom:-10px;width:2px;background:var(--border)}
.tl-item.done::after{background:rgba(34,197,94,.4)}
.tl-dot{width:24px;height:24px;border-radius:50%;border:2px solid var(--border);background:var(--surface2);display:flex;align-items:center;justify-content:center;font-size:10px;flex-shrink:0;margin-top:2px}
.tl-item.done .tl-dot{border-color:var(--green);background:rgba(34,197,94,.2);color:var(--green)}
.tl-item.active .tl-dot{border-color:var(--accent);background:rgba(240,165,0,.2);color:var(--accent);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(240,165,0,.4)}50%{box-shadow:0 0 0 6px rgba(240,165,0,0)}}
.tl-body h4{font-size:13px;font-weight:600}
.tl-body p{font-size:12px;color:var(--muted);margin-top:2px}
.tl-body .tl-time{font-size:10px;color:var(--border2);font-family:var(--mono);margin-top:3px}
.tl-item.done .tl-time,.tl-item.active .tl-time{color:var(--muted)}

/* STAR RATING */
.stars{display:flex;gap:3px}
.star{font-size:18px;cursor:pointer;transition:transform .1s;color:var(--border2)}
.star.lit{color:var(--accent)}
.star:hover{transform:scale(1.2)}

/* OTP BOX */
.otp-box{font-family:var(--mono);font-size:36px;font-weight:700;color:var(--accent);letter-spacing:12px;padding:16px 24px;background:rgba(240,165,0,.08);border:2px dashed rgba(240,165,0,.3);border-radius:var(--radius);text-align:center;margin:12px 0}

/* ATTENDER CARD */
.attender-card{display:flex;align-items:center;gap:14px;padding:14px;background:var(--surface2);border-radius:var(--radius);border:1px solid var(--border)}
.att-avatar{width:48px;height:48px;border-radius:50%;background:rgba(59,130,246,.2);border:2px solid var(--blue);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0}
.att-info{flex:1}
.att-name{font-size:14px;font-weight:600}
.att-role{font-size:11px;color:var(--muted);font-family:var(--mono);margin-top:1px}
.att-rating{display:flex;align-items:center;gap:6px;margin-top:4px}
.att-stars{color:var(--accent);font-size:13px;letter-spacing:1px}
.att-count{font-size:11px;color:var(--muted);font-family:var(--mono)}
.att-status{display:flex;align-items:center;gap:6px}
.att-online{width:8px;height:8px;border-radius:50%;background:var(--green);box-shadow:0 0 6px var(--green)}

/* GEO / MEDIA UPLOAD */
.capture-area{border:1.5px dashed var(--border2);border-radius:var(--radius);padding:20px;text-align:center;cursor:pointer;transition:all .2s;background:var(--surface2)}
.capture-area:hover{border-color:var(--accent);background:rgba(240,165,0,.04)}
.capture-icon{font-size:28px;margin-bottom:8px}
.capture-label{font-size:13px;color:var(--muted)}
.geo-result{background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:10px 14px;font-size:12px;font-family:var(--mono);color:var(--cyan);margin-top:8px;display:none}
.geo-result.show{display:block}
.preview-thumb{width:80px;height:60px;border-radius:6px;object-fit:cover;border:1px solid var(--border)}
.preview-row{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}

/* VIEWS */
.view{display:none}
.view.active{display:block}

/* CHIP TABS */
.chip-tabs{display:flex;gap:6px;margin-bottom:18px;flex-wrap:wrap}
.chip{padding:6px 14px;font-size:12px;border:1px solid var(--border);border-radius:20px;cursor:pointer;color:var(--muted);transition:all .2s;background:transparent}
.chip.active{background:var(--accent);color:#000;border-color:var(--accent);font-weight:600}
.chip:hover:not(.active){color:var(--text);border-color:var(--border2)}

/* ASSIGN MODAL — attender list */
.att-list{display:flex;flex-direction:column;gap:8px;max-height:320px;overflow-y:auto}
.att-select-row{display:flex;align-items:center;gap:12px;padding:12px;background:var(--surface2);border-radius:var(--radius-sm);border:1px solid var(--border);cursor:pointer;transition:all .2s}
.att-select-row:hover{border-color:var(--accent)}
.att-select-row.chosen{border-color:var(--green);background:rgba(34,197,94,.06)}
.att-workload{font-size:11px;color:var(--muted);font-family:var(--mono)}

/* FINANCE AMOUNT */
.amount-pill{font-family:var(--mono);font-weight:600;color:var(--accent);font-size:13px}

/* SEARCH ROW */
.search-row{display:flex;gap:10px;margin-bottom:16px;flex-wrap:wrap}
.search-row input{flex:1;min-width:160px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text);font-family:var(--font);font-size:14px;padding:9px 12px;outline:none}
.search-row input:focus{border-color:var(--accent)}
.search-row select{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text);font-family:var(--font);font-size:13px;padding:9px 12px;outline:none;cursor:pointer}

/* EMPTY */
.empty-state{text-align:center;padding:48px 24px;color:var(--muted)}
.empty-state .ei{font-size:42px;margin-bottom:12px}
.empty-state p{font-size:14px}
.empty-row td{padding:0}

/* RESPONSIVE */
@media(max-width:768px){
  .sidebar{display:none}
  .stats-grid{grid-template-columns:repeat(2,1fr)}
  .form-grid{grid-template-columns:1fr}
}
@media(max-width:480px){.stats-grid{grid-template-columns:1fr}}
</style>
</head>
<body>

<!-- ═══════════════════════════════════
     LOGIN SCREEN
═══════════════════════════════════ -->
<div class="screen active" id="screen-login">
  <div class="login-wrap">
    <div class="login-logo">
      <h1>R<span>&</span>M Portal</h1>
      <p>Repair &amp; Maintenance Management System v2.0</p>
    </div>

    <div style="margin-bottom:16px">
      <div style="font-size:12px;color:var(--muted);font-family:var(--mono);text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px">Select your role</div>
      <div class="role-grid" id="role-grid">
        <div class="role-card selected" data-role="requester" onclick="selectRole(this)">
          <div class="role-icon">🏪</div>
          <div class="role-name">Requester</div>
          <div class="role-sub">Kitchen / Cluster Mgr</div>
        </div>
        <div class="role-card" data-role="supervisor" onclick="selectRole(this)">
          <div class="role-icon">🔧</div>
          <div class="role-name">RM Supervisor</div>
          <div class="role-sub">Assign & coordinate</div>
        </div>
        <div class="role-card" data-role="manager" onclick="selectRole(this)">
          <div class="role-icon">👔</div>
          <div class="role-name">RM Manager</div>
          <div class="role-sub">Approve & oversee</div>
        </div>
        <div class="role-card" data-role="attender" onclick="selectRole(this)">
          <div class="role-icon">🛠️</div>
          <div class="role-name">Attender</div>
          <div class="role-sub">On-ground technician</div>
        </div>
      </div>
    </div>

    <div class="login-form">
      <h2 id="login-form-title">Login as Requester</h2>
      <div class="form-group" id="kitchen-grp">
        <label>Kitchen Location</label>
        <select id="login-kitchen"><option value="">Select Kitchen</option></select>
        <div class="err-msg" id="err-kitchen">Please select your kitchen</div>
      </div>
      <div class="form-group" id="attender-grp" style="display:none">
        <label>Attender Name</label>
        <select id="login-attender"><option value="">Select Attender</option></select>
        <div class="err-msg" id="err-attender">Please select attender</div>
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" id="login-pass" placeholder="Enter password (1234)">
        <div class="err-msg" id="err-pass">Incorrect password</div>
      </div>
      <button class="login-btn" onclick="doLogin()">Login →</button>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════
     APP SCREEN
═══════════════════════════════════ -->
<div class="screen" id="screen-app">
  <div class="app-shell">

    <!-- SIDEBAR -->
    <aside class="sidebar" id="sidebar">
      <div class="logo">
        <div class="logo-icon">⚡</div>
        <div class="logo-text">R<span>&</span>M Portal</div>
      </div>
      <nav class="nav" id="sidebar-nav"></nav>
      <div class="sidebar-footer">
        <div class="nav-item" onclick="logout()" style="color:var(--red)">
          <span class="ni">🚪</span><span>Logout</span>
        </div>
      </div>
    </aside>

    <!-- MAIN -->
    <main class="main-area">
      <div class="topbar">
        <div class="topbar-title">
          <h1 id="page-title">Dashboard</h1>
          <p id="page-sub">Repair &amp; Maintenance</p>
        </div>
        <div class="topbar-user">
          <div class="user-avatar" id="user-avatar">?</div>
          <div>
            <div class="user-name" id="user-name-display"></div>
            <div class="user-role" id="user-role-display"></div>
          </div>
          <button class="btn btn-primary btn-sm" id="new-ticket-btn" onclick="openNewTicketModal()" style="display:none">+ New Ticket</button>
        </div>
      </div>

      <div class="content" id="main-content"></div>
    </main>
  </div>
</div>

<!-- ═══════════════════════════════════
     MODALS
═══════════════════════════════════ -->

<!-- NEW TICKET -->
<div class="overlay" id="modal-new-ticket">
  <div class="modal">
