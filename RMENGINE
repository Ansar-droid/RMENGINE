let selectedRole = 'requester';

function selectRole(el){
  document.querySelectorAll('.role-card').forEach(c=>c.classList.remove('selected'));
  el.classList.add('selected');
  selectedRole = el.dataset.role;
  const titles={requester:'Login as Requester',supervisor:'Login as RM Supervisor',manager:'Login as RM Manager',attender:'Login as Attender'};
  document.getElementById('login-form-title').textContent = titles[selectedRole];
  document.getElementById('kitchen-grp').style.display = selectedRole==='attender'?'none':'block';
  document.getElementById('attender-grp').style.display = selectedRole==='attender'?'block':'none';
}

function doLogin(){
  const pass = document.getElementById('login-pass').value;
  let ok = true;
  // clear errors
  ['err-kitchen','err-attender','err-pass'].forEach(id=>{
    const e=document.getElementById(id); if(e) e.classList.remove('show');
  });
  ['login-kitchen','login-attender','login-pass'].forEach(id=>{
    const e=document.getElementById(id); if(e) e.classList.remove('err');
  });

  let kitchenCode='', attenderObj=null;

  if(selectedRole!=='attender'){
    kitchenCode = document.getElementById('login-kitchen').value;
    if(!kitchenCode){ document.getElementById('err-kitchen').classList.add('show'); document.getElementById('login-kitchen').classList.add('err'); ok=false; }
  } else {
    const attId = document.getElementById('login-attender').value;
    if(!attId){ document.getElementById('err-attender').classList.add('show'); document.getElementById('login-attender').classList.add('err'); ok=false; }
    else attenderObj = ATTENDERS.find(a=>a.id===attId);
  }
  if(pass!=='1234'){ document.getElementById('err-pass').classList.add('show'); document.getElementById('login-pass').classList.add('err'); ok=false; }
  if(!ok) return;

  currentUser = {
    role: selectedRole,
    kitchenCode: kitchenCode||'',
    name: attenderObj ? attenderObj.name : (selectedRole==='manager'?'Philips Kenny':selectedRole==='supervisor'?'Mahesh Kumar':'Kitchen Manager'),
    attenderId: attenderObj?.id||null,
    attenderObj
  };
  localStorage.setItem('rmUser', JSON.stringify(currentUser));
  initApp();
}

function logout(){
  localStorage.removeItem('rmUser');
  currentUser=null; activeTicketId=null;
  document.getElementById('screen-login').classList.add('active');
  document.getElementById('screen-app').classList.remove('active');
  document.getElementById('login-pass').value='';
}

